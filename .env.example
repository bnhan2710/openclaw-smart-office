EMBEDDING_MODEL=text-embedding-3-small

# ── knowledge-base: cấu hình RAG ──────────────────────────────────────────────
KB_DATA_DIR=./data/knowledge-base
KB_INDEX_DIR=./data/kb-index
SIMILARITY_THRESHOLD=0.75
TOP_K=5

# ── soan-thao: thông tin cơ quan ──────────────────────────────────────────────
# Agent dùng model OpenClaw để soạn nội dung.
# Script chỉ dùng các biến này để điền tiêu đề và số hiệu văn bản.
CO_QUAN_TEN=ĐƠN VỊ
CO_QUAN_KY_HIEU=DV
OUTPUT_DIR=./output/van-ban

# ── deadline-reminder: kênh thông báo ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (tuỳ chọn, thay thế hoặc kết hợp Telegram)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Lịch nhắc
REMINDER_DAYS_BEFORE=3,1
REMINDER_TIME=08:00
DEADLINES_FILE=./data/deadlines.json
